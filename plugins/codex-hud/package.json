{
  "name": "codex-hud",
  "version": "0.1.0",
  "description": "Real-time HUD for Codex sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codex-hud": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "skills/",
    "commands/",
    "scripts/",
    ".codex-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && c8 --reporter=text --reporter=lcov node --test",
    "test:update-snapshots": "UPDATE_SNAPSHOTS=1 npm test",
    "test:stdin": "npm run build && echo '{\"model\":{\"display_name\":\"GPT-5\"},\"context_window\":{\"current_usage\":{\"input_tokens\":45000},\"context_window_size\":200000},\"transcript_path\":\"/tmp/test.jsonl\"}' | node dist/index.js",
    "hud": "npm run build && node dist/index.js"
  },
  "keywords": [
    "codex",
    "statusline",
    "hud"
  ],
  "author": "panzhufeng",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "c8": "^11.0.0",
    "typescript": "^6.0.3"
  }
}
